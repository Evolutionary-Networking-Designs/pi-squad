{
  "name": "@pi-squad/coordinator",
  "version": "0.1.0",
  "description": "Bring Squad's multi-agent coordination to Pi — your whole team, no cloud required",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "squad/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pi",
    "squad",
    "multi-agent",
    "coordinator",
    "ai",
    "copilot"
  ],
  "author": "Evolutionary Networking Designs and contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Evolutionary-Networking-Designs/pi-squad.git"
  },
  "license": "MIT",
  "acknowledgements": [
    {
      "name": "Pi",
      "author": "Mario Zechner",
      "url": "https://github.com/earendil-works/pi",
      "license": "MIT"
    },
    {
      "name": "Squad",
      "author": "Brady Gaster and contributors",
      "url": "https://github.com/bradygaster/squad",
      "license": "MIT"
    },
    {
      "name": "rpiv-ask-user-question",
      "author": "juicesharp",
      "url": "https://github.com/juicesharp/rpiv-mono",
      "license": "MIT"
    }
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "squad": {
    "version": "0.9.4",
    "commit": "",
    "minVersion": "0.9.0",
    "maxVersion": "0.10.x"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@types/pg": "^8.20.0",
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^12.10.0",
    "pg": "^8.21.0",
    "semver": "^7.6.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.8",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
